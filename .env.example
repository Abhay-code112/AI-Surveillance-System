# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///./surveillance.db

# ── Authentication ──────────────────────────────────────────────
# Replace with a secure random string (e.g., openssl rand -hex 32)
JWT_SECRET_KEY=local_dev_secret_key

# ── Alert System (Optional) ───────────────────────────────────
# If left blank, the alert system will gracefully skip sending.

# Email Alerts (Gmail)
# 1. Turn on 2-Step Verification for your Google Account.
# 2. Go to App Passwords and generate a new password for "Mail".
# 3. Paste the 16-character password below.
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVER=

# Telegram Alerts
# 1. Open Telegram and message @BotFather.
# 2. Send /newbot and follow instructions to get your HTTP API Token.
# 3. Send a message to your new bot.
# 4. Visit https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
